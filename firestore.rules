rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- POMOCNÉ GLOBÁLNÍ FUNKCE ---
    function isLogged() {
      return request.auth != null;
    }
    
    function isSuperAdmin() {
      return isLogged() && request.auth.token.isSuperAdmin == true;
    }
    
    function isAdmin() {
      return isSuperAdmin() || (isLogged() && request.auth.token.isAdmin == true);
    }

    // --- KOLEKCE UŽIVATELŮ A SEZÓNNÍ MONOLITY ---
    match /users/{userId} {
      // 🔒 ROZDĚLENÍ READ PRÁV: 'get' chrání soukromí profilu, 'list' umožní frontendu ověřit duplicitu nicku
      allow get: if isLogged() && (request.auth.uid == userId || isAdmin());
      allow list: if isLogged();
      
      allow create: if isLogged() && (
        isSuperAdmin() || isAdmin() || (
          request.auth.uid == userId && 
          request.resource.data.get('isAdmin', false) == false && 
          request.resource.data.get('leagues', []).size() == 0
        )
      );
      
      allow update: if isLogged() && (
        isSuperAdmin() || isAdmin() || (
          request.auth.uid == userId && 
          request.resource.data.get('isAdmin', false) == resource.data.get('isAdmin', false) &&
          request.resource.data.get('leagues', []) == resource.data.get('leagues', [])
        )
      );
      
      allow delete: if isSuperAdmin() || isAdmin();

      match /sezony/{sezonaId} {
        allow read: if isLogged() && (request.auth.uid == userId || isAdmin());
        allow write: if isAdmin();
      }
    }

    // --- LIGOVÝ APARÁT A ZÁPASY ---
    match /ligy/{ligaId} {
      allow read: if isLogged() && (
        isSuperAdmin() || 
        ligaId in request.auth.token.get('leagues', [])
      );
      allow write: if isAdmin();

      match /zapasy/{zapasId} {
        allow read: if isLogged() && (isSuperAdmin() || ligaId in request.auth.token.get('leagues', []));
        allow write: if isAdmin();
      }

      // 👑 NOVÝ REGISTR SCHVÁLENÝCH HRÁČŮ PRO BALÍČEK 1 (Giga-úspora čtení žebříčku)
      match /stav/registrovani {
        allow read: if isLogged() && (isSuperAdmin() || ligaId in request.auth.token.get('leagues', []));
        allow write: if isAdmin();
      }

      match /stav/{stavId} {
        allow read: if isLogged() && (isSuperAdmin() || ligaId in request.auth.token.get('leagues', []));
        allow write: if isAdmin();
      }
    }

    // --- DOPLŇKOVÉ KOLEKCE (ONLINE RADARY) ---
    match /uzivatele_online/{userId} {
      allow read: if isLogged();
      allow write: if isLogged() && request.auth.uid == userId;
    }
  }
}